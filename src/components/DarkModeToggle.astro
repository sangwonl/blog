---
---

<theme-selector class="flex">
  <div class="theme-options" role="group" aria-label="Theme">
    <button type="button" data-theme="light" aria-pressed="false">Light</button>
    <button type="button" data-theme="dark" aria-pressed="false">Dark</button>
    <button type="button" data-theme="tty" aria-pressed="false">TTY</button>
  </div>
</theme-selector>

<script>
  type Theme = "light" | "dark" | "tty";

  const themeColors: Record<Theme, string> = {
    light: "#ffffff",
    dark: "#0e141b",
    tty: "#031109",
  };

  class ThemeSelector extends HTMLElement {
    connectedCallback() {
      const buttons = this.querySelectorAll<HTMLButtonElement>("[data-theme]");

      const updateSelection = (theme: Theme) => {
        buttons.forEach((button) => {
          button.setAttribute(
            "aria-pressed",
            String(button.dataset.theme === theme)
          );
        });
      };

      const currentTheme = (): Theme => {
        if (document.documentElement.classList.contains("tty")) return "tty";
        if (document.documentElement.classList.contains("dark")) return "dark";
        return "light";
      };

      updateSelection(currentTheme());

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const theme = button.dataset.theme as Theme;
          document.documentElement.classList.remove("light", "dark", "tty");
          document.documentElement.classList.add(theme);
          localStorage.setItem("theme", theme);

          const meta = document.head.querySelector<HTMLMetaElement>(
            'meta[name="theme-color"]'
          );
          if (meta) meta.content = themeColors[theme];

          updateSelection(theme);
        });
      });
    }
  }

  if (!customElements.get("theme-selector")) {
    customElements.define("theme-selector", ThemeSelector);
  }
</script>

<style>
  .theme-options {
    display: inline-grid;
    grid-template-columns: repeat(3, auto);
    overflow: hidden;
    border: 1px solid rgb(var(--color-text-muted) / 0.45);
    border-radius: 0.25rem;
  }

  button {
    min-width: 2.65rem;
    padding: 0.2rem 0.4rem;
    border-left: 1px solid rgb(var(--color-text-muted) / 0.35);
    color: rgb(var(--color-text-muted));
    background: transparent;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
      "Liberation Mono", monospace;
    font-size: 0.625rem;
    font-weight: 700;
    line-height: 1.25rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 150ms ease, background-color 150ms ease,
      box-shadow 150ms ease;
  }

  button:first-child {
    border-left: 0;
  }

  button:hover,
  button:focus-visible {
    color: rgb(var(--color-text-link));
    background: rgb(var(--color-primary-main) / 0.08);
  }

  button:focus-visible {
    position: relative;
    z-index: 1;
    outline: 2px solid rgb(var(--color-text-link));
    outline-offset: -2px;
  }

  button[aria-pressed="true"] {
    color: rgb(var(--color-text-selection));
    background: rgb(var(--color-bg-selection));
  }

  :global(html.tty) button[aria-pressed="true"] {
    color: rgb(var(--color-text-heading));
    background: rgb(var(--color-primary-main) / 0.12);
    box-shadow: inset 0 0 0 1px rgb(var(--color-primary-main) / 0.75),
      0 0 0.7rem rgb(var(--color-primary-main) / 0.28);
    text-shadow: 0 0 0.35rem rgb(var(--color-primary-main) / 0.65);
  }

  @media (prefers-reduced-motion: reduce) {
    button {
      transition: none;
    }
  }
</style>
